# Example per-user configuration (~/.config/depot.toml)

[build]
prefix = "/usr/local"
cc = "clang"

[build.flags]
cflags = ["-O2"]
cflags += ["-g"]
carch = "x86_64"

[install]
test_deps = false

# Optional install directory overrides for supported builders
#bindir = "/usr/local/bin"
#sbindir = "/usr/local/sbin"
#libdir = "/usr/local/lib"
